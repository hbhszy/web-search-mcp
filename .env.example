# DeepSeek authentication (at least one is required)
DEEPSEEK_AUTH_TOKEN=
DEEPSEEK_COOKIE=

# DeepSeek model settings
# modelType: "default" or "expert"
DEEPSEEK_MODEL_TYPE=default
# thinkingEnabled: true/false - enable DeepSeek thinking/reasoning mode
DEEPSEEK_THINKING_ENABLED=false

# Path to the WASM PoW solver binary (default: assets/sha3_wasm_bg.7b9ca65ddd.wasm)
# WASM_PATH=

# Log level: debug, info, error
LOG_LEVEL=info
